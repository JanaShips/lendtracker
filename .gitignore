# ============================================
# LendTracker .gitignore
# ============================================

# ============================================
# Java / Maven
# ============================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ============================================
# IDE
# ============================================
.idea/
*.iws
*.iml
*.ipr
.vscode/
*.swp
*.swo
.project
.classpath
.settings/

# ============================================
# OS Files
# ============================================
.DS_Store
Thumbs.db
*.log

# ============================================
# Environment & Secrets
# ============================================
.env
.env.local
.env.production
.env.*.local
*.env
!production.env
!env.example

# Application properties with secrets (if you create a local override)
application-local.properties
application-secrets.properties

# ============================================
# Node / Frontend
# ============================================
lendtracker-ui/node_modules/
lendtracker-ui/dist/
lendtracker-ui/.env
lendtracker-ui/.env.production
lendtracker-ui/.env.local

# ============================================
# Android Build Artifacts
# ============================================
lendtracker-ui/android/.gradle/
lendtracker-ui/android/app/build/
lendtracker-ui/android/build/
lendtracker-ui/android/capacitor-cordova-android-plugins/build/
lendtracker-ui/android/local.properties
lendtracker-ui/android/keystore.properties
*.apk
*.aab
*.keystore
*.jks

# ============================================
# iOS Build Artifacts
# ============================================
lendtracker-ui/ios/App/Pods/
lendtracker-ui/ios/App/build/
lendtracker-ui/ios/DerivedData/
lendtracker-ui/ios/App/App/public/
*.xcuserdata

# ============================================
# Android Bundled Web Assets (regenerated by cap sync)
# ============================================
lendtracker-ui/android/app/src/main/assets/public/

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# Database
# ============================================
*.db
*.sqlite
